// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

// ─────────────────────────────────────────────────────────────────────────────
// ERP Schema — generated from DBML model
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Catalog / lookup ─────────────────────────────────────────────────────────

model Gender {
  id         String    @id @default(uuid()) @db.Uuid
  code       String    @unique @db.Char(1)
  name       String    @db.VarChar(50)
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  products   Product[]

  @@index([active])
  @@map("gender")
}

model Category {
  id         String    @id @default(uuid()) @db.Uuid
  code       String    @unique @db.Char(2)
  name       String    @db.VarChar(100)
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  products          Product[]
  equivalenceTables EquivalenceTable[]

  @@index([active])
  @@map("category")
}

// ─── Third parties (base for customers & suppliers) ──────────────────────────

model ThirdParty {
  id             String    @id @default(uuid()) @db.Uuid
  name           String
  email          String?   @unique
  phone          String?
  address        String?
  isActive       Boolean   @default(true) @map("is_active")
  isSeller       Boolean   @default(false) @map("is_seller")
  isCustomer     Boolean   @default(false) @map("is_customer")
  isSupplier     Boolean   @default(false) @map("is_supplier")
  personType     String    @map("person_type") @db.VarChar(10)
  documentType   String    @map("document_type") @db.VarChar(20)
  documentNumber String    @unique @map("document_number") @db.VarChar(50)
  firstName      String?   @map("first_name") @db.VarChar(100)
  lastName       String?   @map("last_name") @db.VarChar(100)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz
  deletedById    String?   @map("deleted_by_id") @db.Uuid
  createdAt      DateTime? @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime? @updatedAt @map("updated_at") @db.Timestamptz

  customer           Customer?
  supplier           Supplier?
  documents          Document[]
  soldToCustomers    Customer[]           @relation("SellerThirdParty")
  accountsReceivable AccountsReceivable[] @relation("SellerAR")
  equivalenceTables  EquivalenceTable[]
  deletedBy          User?                @relation("ThirdPartyDeletedBy", fields: [deletedById], references: [id])

  @@index([isActive])
  @@index([isCustomer])
  @@index([isSupplier])
  @@index([createdAt])
  @@map("third_parties")
}

// ─── Customer ─────────────────────────────────────────────────────────────────

model Customer {
  id          String   @id @db.Uuid
  sellerId    String?  @map("seller_id") @db.Uuid
  creditLimit Decimal? @map("credit_limit") @db.Decimal(14, 2)
  discount    Decimal? @db.Decimal(5, 2)

  thirdParty         ThirdParty          @relation(fields: [id], references: [id])
  seller             ThirdParty?         @relation("SellerThirdParty", fields: [sellerId], references: [id])
  accountsReceivable AccountsReceivable[]
  customerCredits    CustomerCredit[]

  @@map("customers")
}

// ─── Supplier ─────────────────────────────────────────────────────────────────

model Supplier {
  id             String  @id @db.Uuid
  internalNumber Int    @unique @map("internal_number")

  thirdParty      ThirdParty       @relation(fields: [id], references: [id])
  brands          Brand[]
  accountsPayable AccountsPayable[]

  @@map("suppliers")
}

// ─── Brand ────────────────────────────────────────────────────────────────────

model Brand {
  id         String   @id @default(uuid()) @db.Uuid
  name       String   @db.VarChar(100)
  active     Boolean  @default(true)
  supplierId String   @map("supplier_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  supplier Supplier @relation(fields: [supplierId], references: [id])
  products Product[]

  @@index([active])
  @@index([supplierId])
  @@map("brand")
}

// ─── Product ──────────────────────────────────────────────────────────────────

model Product {
  id            String   @id @default(uuid()) @db.Uuid
  code          String   @unique @db.VarChar(15)
  legacyCode    String?  @map("legacy_code") @db.VarChar(15)
  description   String   @db.VarChar(300)
  brandId       String   @map("brand_id") @db.Uuid
  genderId      String   @map("gender_id") @db.Uuid
  categoryId    String   @map("category_id") @db.Uuid
  salePrice     Int  @map("sale_price")
  minSalePrice  Int  @map("min_sale_price")
  active        Boolean   @default(true)
  avgCost       Decimal   @default(0) @map("avg_cost") @db.Decimal(14, 4)
  lastCost      Decimal   @default(0) @map("last_cost") @db.Decimal(14, 4)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz
  deletedById   String?   @map("deleted_by_id") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  brand     Brand    @relation(fields: [brandId], references: [id])
  gender    Gender   @relation(fields: [genderId], references: [id])
  category  Category @relation(fields: [categoryId], references: [id])
  deletedBy User?    @relation("ProductDeletedBy", fields: [deletedById], references: [id])

  documentItems      DocumentItem[]
  inventoryRecords   Inventory[]
  inventoryMovements InventoryMovement[]
  inventorySnapshots InventorySnapshot[]

  @@index([active])
  @@index([brandId])
  @@index([genderId])
  @@index([categoryId])
  @@index([createdAt])
  @@index([active, brandId])
  @@index([active, categoryId])
  @@index([active, genderId])
  @@map("product")
}

// ─── Equivalence table ────────────────────────────────────────────────────────

model EquivalenceTable {
  id             String   @id @default(uuid()) @db.Uuid
  supplierId     String   @map("supplier_id") @db.Uuid
  categoryId     String   @map("category_id") @db.Uuid
  equivalentCode String   @map("equivalent_code") @db.VarChar(100)
  cost           String   @db.VarChar(5)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  supplier ThirdParty @relation(fields: [supplierId], references: [id])
  category Category   @relation(fields: [categoryId], references: [id])

  @@map("equivalence_table")
}

// ─── Warehouse / location ─────────────────────────────────────────────────────

enum WarehouseType {
  store
  warehouse
}

model Warehouse {
  id        String        @id @default(uuid()) @db.Uuid
  name      String        @db.VarChar(100)
  type      WarehouseType
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  zones              Zone[]
  inventoryRecords   Inventory[]
  inventoryMovements InventoryMovement[]
  inventorySnapshots InventorySnapshot[]
  documents          Document[]          @relation("DocumentWarehouse")
  destDocuments      Document[]          @relation("DocumentDestWarehouse")

  @@map("warehouse")
}

model Zone {
  id          String   @id @default(uuid()) @db.Uuid
  warehouseId String   @map("warehouse_id") @db.Uuid
  name        String   @db.VarChar(100)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  bins      Bin[]

  @@map("zone")
}

model Bin {
  id        String   @id @default(uuid()) @db.Uuid
  zoneId    String   @map("zone_id") @db.Uuid
  name      String   @db.VarChar(100)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  zone               Zone                @relation(fields: [zoneId], references: [id])
  inventoryRecords   Inventory[]
  inventoryMovements InventoryMovement[]
  inventorySnapshots InventorySnapshot[]
  destDocuments      Document[]          @relation("DocumentDestBin")

  @@map("bin")
}

// ─── Inventory ────────────────────────────────────────────────────────────────

model Inventory {
  productId   String  @map("product_id") @db.Uuid
  warehouseId String  @map("warehouse_id") @db.Uuid
  binId       String? @map("bin_id") @db.Uuid
  quantity    Int @default(0)

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  bin       Bin?      @relation(fields: [binId], references: [id])

  @@id([productId, warehouseId])
  @@map("inventory")
}

enum MovementType {
  purchase
  sale
  return
  transfer
  adjustment
  initial_stock
  void
  production
}

model InventoryMovement {
  id           String       @id @default(uuid()) @db.Uuid
  productId    String       @map("product_id") @db.Uuid
  warehouseId  String       @map("warehouse_id") @db.Uuid
  binId        String?      @map("bin_id") @db.Uuid
  movementType MovementType @map("movement_type")
  /// positive or negative
  quantity      Int
  unitCost      Decimal  @default(0) @map("unit_cost") @db.Decimal(14, 4)
  previousStock Int?     @map("previous_stock")
  newStock      Int?     @map("new_stock")
  documentId    String?  @map("document_id") @db.Uuid
  documentItemId String? @map("document_item_id") @db.Uuid
  userId        String?  @map("user_id") @db.Uuid
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  product      Product       @relation(fields: [productId], references: [id])
  warehouse    Warehouse     @relation(fields: [warehouseId], references: [id])
  bin          Bin?          @relation(fields: [binId], references: [id])
  document     Document?     @relation(fields: [documentId], references: [id])
  documentItem DocumentItem? @relation(fields: [documentItemId], references: [id])
  user         User?         @relation(fields: [userId], references: [id])

  @@index([productId])
  @@index([warehouseId])
  @@index([createdAt])
  @@index([movementType])
  @@map("inventory_movements")
}

model InventorySnapshot {
  snapshotDate DateTime  @map("snapshot_date") @db.Date
  /// daily | weekly | monthly
  periodType   String    @default("daily") @map("period_type") @db.VarChar(10)
  productId    String    @map("product_id") @db.Uuid
  warehouseId  String    @map("warehouse_id") @db.Uuid
  binId        String?   @map("bin_id") @db.Uuid
  quantity     Int

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  bin       Bin?      @relation(fields: [binId], references: [id])

  @@id([snapshotDate, periodType, productId, warehouseId])
  @@map("inventory_snapshot")
}

// ─── Users / roles / permissions ─────────────────────────────────────────────

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique @db.VarChar(100)
  module      String   @db.VarChar(50)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  rolePermissions RolePermission[]

  @@map("permission")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(50)
  description String?  @db.VarChar(200)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@map("role")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permission")
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @db.VarChar(150)
  username         String  @unique @db.VarChar(150)
  password String  @db.VarChar(255)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  userRoles             UserRole[]
  documents             Document[]
  inventoryMovements    InventoryMovement[]
  deletedProducts       Product[]     @relation("ProductDeletedBy")
  deletedThirdParties   ThirdParty[]  @relation("ThirdPartyDeletedBy")

  @@map("user")
}

model UserRole {
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@map("user_role")
}

// ─── Documents ────────────────────────────────────────────────────────────────

enum DocumentType {
  CM // Compra — entrada inventario + CxP
  DVC // Devolución en compra — salida inventario + reduce CxP
  RMDVC // Remisión dev. compra — temporal, sin efecto inventario
  PE // Pedido — temporal, se convierte en CM
  EAI // Entrada ajuste inventario
  SAJ // Salida ajuste inventario
  COT // Venta a crédito — salida inventario + CxC
  POS // Venta de contado — salida inventario
  REM // Remisión — temporal, se convierte en COT/POS
  DVV // Devolución en venta — entrada inventario + saldo a favor
  T // Traslado entre bodegas
}

enum DocumentStatus {
  draft
  confirmed
  voided
}

model Document {
  id               String         @id @default(uuid()) @db.Uuid
  type             DocumentType
  number           String         @db.VarChar(30)
  date             DateTime       @db.Date
  thirdPartyId     String?        @map("third_party_id") @db.Uuid
  userId           String         @map("user_id") @db.Uuid
  status           DocumentStatus @default(draft)
  total            Decimal        @default(0) @db.Decimal(16, 2)
  freight          Decimal?       @db.Decimal(14, 2)
  notes            String?
  /// Bodega principal: destino en CM/EAI, origen en DVC/SAJ/T
  warehouseId      String?        @map("warehouse_id") @db.Uuid
  /// Bodega destino — solo traslados (T)
  destWarehouseId  String?        @map("dest_warehouse_id") @db.Uuid
  /// Bulto destino — solo traslados hacia bodega de almacenamiento
  destBinId        String?        @map("dest_bin_id") @db.Uuid
  sourceDocumentId String?        @map("source_document_id") @db.Uuid
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  thirdParty       ThirdParty? @relation(fields: [thirdPartyId], references: [id])
  user             User        @relation(fields: [userId], references: [id])
  warehouse        Warehouse?  @relation("DocumentWarehouse", fields: [warehouseId], references: [id])
  destWarehouse    Warehouse?  @relation("DocumentDestWarehouse", fields: [destWarehouseId], references: [id])
  destBin          Bin?        @relation("DocumentDestBin", fields: [destBinId], references: [id])
  sourceDocument   Document?   @relation("DocumentSource", fields: [sourceDocumentId], references: [id])
  derivedDocuments Document[]  @relation("DocumentSource")

  documentItems      DocumentItem[]
  inventoryMovements InventoryMovement[]
  accountsReceivable AccountsReceivable[]
  accountsPayable    AccountsPayable[]
  customerCredits    CustomerCredit[]

  @@unique([type, number])
  @@index([type, status])
  @@index([date])
  @@index([thirdPartyId])
  @@map("document")
}

model DocumentItem {
  id            String   @id @default(uuid()) @db.Uuid
  documentId    String   @map("document_id") @db.Uuid
  productId     String   @map("product_id") @db.Uuid
  /// C | F | null
  referenceType String?  @map("reference_type") @db.Char(1)
  references    String?
  quantity      Int
  unitPrice     Decimal  @default(0) @map("unit_price") @db.Decimal(14, 4)
  unitCost      Decimal  @default(0) @map("unit_cost") @db.Decimal(14, 4)
  subtotal      Decimal  @default(0) @db.Decimal(16, 2)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  document Document @relation(fields: [documentId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])

  inventoryMovements InventoryMovement[]

  @@map("document_item")
}

// ─── Accounts receivable ─────────────────────────────────────────────────────

model AccountsReceivable {
  id          String    @id @default(uuid()) @db.Uuid
  clientId    String    @map("client_id") @db.Uuid
  sellerId    String    @map("seller_id") @db.Uuid
  documentId  String    @map("document_id") @db.Uuid
  totalAmount Decimal   @map("total_amount") @db.Decimal(16, 2)
  dueDate     DateTime? @map("due_date") @db.Date
  /// pending | partial | paid
  status      String    @default("pending") @db.VarChar(10)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  client   Customer   @relation(fields: [clientId], references: [id])
  seller   ThirdParty @relation("SellerAR", fields: [sellerId], references: [id])
  document Document   @relation(fields: [documentId], references: [id])

  receivablePayments ReceivablePayment[]

  @@map("accounts_receivable")
}

model ReceivablePayment {
  id                   String   @id @default(uuid()) @db.Uuid
  accountReceivableId  String   @map("account_receivable_id") @db.Uuid
  amount               Decimal  @db.Decimal(16, 2)
  paymentDate          DateTime @map("payment_date") @db.Date
  paymentMethod        String   @map("payment_method")
  reference            String?
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz

  accountReceivable AccountsReceivable @relation(fields: [accountReceivableId], references: [id])

  @@map("receivable_payments")
}

// ─── Accounts payable ────────────────────────────────────────────────────────

model AccountsPayable {
  id          String    @id @default(uuid()) @db.Uuid
  supplierId  String    @map("supplier_id") @db.Uuid
  documentId  String    @map("document_id") @db.Uuid
  totalAmount Decimal   @map("total_amount") @db.Decimal(16, 2)
  dueDate     DateTime? @map("due_date") @db.Date
  /// pending | partial | paid
  status      String    @default("pending") @db.VarChar(10)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  supplier        Supplier         @relation(fields: [supplierId], references: [id])
  document        Document         @relation(fields: [documentId], references: [id])
  payablePayments PayablePayment[]

  @@map("accounts_payable")
}

model PayablePayment {
  id               String   @id @default(uuid()) @db.Uuid
  accountPayableId String   @map("account_payable_id") @db.Uuid
  amount           Decimal  @db.Decimal(16, 2)
  paymentDate      DateTime @map("payment_date") @db.Date
  paymentMethod    String   @map("payment_method")
  bankDestination  String?  @map("bank_destination")
  reference        String?
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz

  accountPayable AccountsPayable @relation(fields: [accountPayableId], references: [id])

  @@map("payable_payments")
}

// ─── Customer credit (saldo a favor) ─────────────────────────────────────────

model CustomerCredit {
  id               String   @id @default(uuid()) @db.Uuid
  thirdPartyId     String   @map("third_party_id") @db.Uuid
  amount           Decimal  @db.Decimal(16, 2)
  balance          Decimal  @db.Decimal(16, 2)
  sourceDocumentId String?  @map("source_document_id") @db.Uuid
  /// available | used | expired
  status           String   @db.VarChar(10)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz

  customer       Customer  @relation(fields: [thirdPartyId], references: [id])
  sourceDocument Document? @relation(fields: [sourceDocumentId], references: [id])

  @@map("customer_credit")
}

